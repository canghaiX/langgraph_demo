# =========================
# OpenAI-compatible models
# =========================
# 如果你的服务不校验 key，可以填 EMPTY。
CHAT_API_KEY=EMPTY
CHAT_BASE_URL=http://127.0.0.1:8000/v1
CHAT_MODEL=Qwen3-8B

EMBEDDING_API_KEY=EMPTY
EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
EMBEDDING_MAX_TOKENS=8192

# =========================
# LightRAG
# =========================
LIGHTRAG_WORKDIR=.lightrag_cache
LIGHTRAG_QUERY_MODE=hybrid
LIGHTRAG_RESPONSE_TYPE=Multiple Paragraphs
LIGHTRAG_LANGUAGE=Simplified Chinese
CHUNK_TOKEN_SIZE=1200
CHUNK_OVERLAP_TOKEN_SIZE=100
SEMANTIC_CHUNK_MIN_TOKENS=80
SEMANTIC_CHUNK_OVERLAP_SENTENCES=1
PREFERENCE_STORE_PATH=.memory/preferences.json
SESSION_SUMMARY_STORE_PATH=.memory/session_summaries.json
DEFAULT_USER_ID=default_user
SESSION_MEMORY_MAX_MESSAGES=10
SESSION_MEMORY_RECENT_MESSAGES=6

# =========================
# Reranker
# =========================
RERANKER_MODEL_PATH=/path/to/bge-reranker-large
RERANKER_DEVICE=cuda
RERANKER_TOP_K=5

# =========================
# MCP tools
# =========================
ENABLE_MCP_WEB_SEARCH=true
ENABLE_MCP_FILESYSTEM=true
MCP_WEB_SEARCH_MAX_RESULTS=5
MCP_FILESYSTEM_ROOT=.

# =========================
# Assistant behavior
# =========================
SYSTEM_PROMPT=你是一个严谨的中文知识库助手。请优先依据检索到的上下文回答；如果上下文不足，请明确说明，不要编造。
